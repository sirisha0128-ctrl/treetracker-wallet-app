{
  "compilerOptions": {
    "types": ["node", "@wdio/globals/types"],
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "rootDir": ".",
    "strict": true,
    "noImplicitAny": false,
    "baseUrl": ".",
    "paths": {
      "@wdio/globals": ["node_modules/@wdio/globals/types"]
    }
  },
  "include": [
    "**/*.ts",
    ".wdio.conf.ts",
    "features/**/*.ts",
    "mocks/*.ts",
    "support/*.ts",
    "mocks/hooks"
  ],
  "exclude": ["node_modules"]
}
