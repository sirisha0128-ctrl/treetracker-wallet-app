{
  "name": "web",
  "version": "5.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev &&  yarn workspace wallet_state loadEnv",
    "build": "next build",
    "start": "next start && yarn workspace wallet_state loadEnv",
    "lint": "eslint .",
    "lint:check": "eslint . --ignore-pattern '**/.next/**' --ignore-pattern '.history/**'",
    "lint:fix": "eslint . --fix  --ignore-pattern '**/.next/**' --ignore-pattern '.history/**'",
    "format": "prettier --write 'src/**/*.{js,jsx,ts,tsx}'",
    "format:check": "prettier --check 'src/**/*.{js,jsx,ts,tsx}'",
    "pre-commit": "yarn pre-commit",
    "lint-staged": "yarn lint-staged",
    "cy:component": "cypress run --component",
    "cy:e2e": "start-server-and-test dev http://localhost:3000 \"cypress open --e2e\"",
    "cy:e2e-headless": "start-server-and-test dev http://localhost:3000 \"cypress run --e2e\"",
    "cy:debug": "cypress run --component --headed",
    "cy:open": "cypress open"
  },
  "dependencies": {
    "@emotion/cache": "11.13.1",
    "@emotion/react": "11.13.0",
    "@emotion/styled": "11.13.0",
    "@mui/icons-material": "6.0.2",
    "@mui/lab": "^5.0.0-alpha.137",
    "@mui/material": "6.0.2",
    "@mui/material-nextjs": "6.0.2",
    "@mui/system": "6.0.2",
    "@mui/utils": "6.0.2",
    "@mui/x-date-pickers": "^6.9.1",
    "@treetracker/wallet": "0.0.1",
    "@types/react-no-ssr": "1.1.7",
    "core": "1.0.0",
    "date-fns": "^2.30.0",
    "dayjs": "^1.11.9",
    "jotai": "^2.9.0",
    "next": "15.0.4",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-no-ssr": "1.1.0"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "cypress": "14.0.0",
    "eslint": "10.1.0",
    "eslint-config-next": "15.0.4",
    "prettier": "^3.4.2",
    "start-server-and-test": "^2.0.12",
    "typescript": "5.9.3"
  }
}
